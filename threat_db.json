    "Trojan.SalineWin": {
      "description": "SalineWin \u2014 C++ GDI trojan. Disables Task Manager, overwrites MBR with toad image at offset 32768 via PhysicalDrive0 direct write.",
      "strings": [
        "DisableTaskMgr",
        "policies\\system /v DisableTaskMgr",
        "REG ADD hkcu\\Software\\Microsoft\\Windows\\CurrentVersion\\policies\\system",
        "/v DisableTaskMgr /t reg_dword /d 1 /f",
        "salinewin",
        "SalineWin",
        "SALINEWIN"
      ],
      "condition": "any_1",
      "severity": "critical"
    },
    "Behavior.MBRTamper": {
      "description": "Direct MBR/disk write \u2014 wiper, bootkit, or SalineWin payload",
      "strings": [
        "\\\\.\\PhysicalDrive0",
        "\\\\.\\PhysicalDrive1",
        "\\\\PHYSICALDRIVE"
      ],
      "condition": "any_1",
      "severity": "critical"
    },
    "Behavior.DisableTaskManager": {
      "description": "Malware disabling Task Manager \u2014 seen in SalineWin, ransomware, trojans",
