{
  "name": "bytesprotector",
  "version": "1.0.0",
  "description": "BytesProtector \u2014 Multi-engine antivirus suite",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "pack": "electron-builder --dir",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "org.bytesprotectorav.app",
    "productName": "BytesProtector",
    "icon": "assets/icon.png",
    "win": {
      "icon": "assets/icon.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "requestedExecutionLevel": "requireAdministrator"
    },
    "mac": {
      "icon": "assets/icon.png",
      "target": [
        "dmg"
      ]
    },
    "linux": {
      "icon": "assets/icon.png",
      "target": [
        "AppImage",
        "deb"
      ]
    },
    "asar": true,
    "asarUnpack": [
      "backend/**",
      "config/**",
      "assets/**"
    ],
    "files": [
      "**/*",
      "!node_modules/.cache",
      "!**/*.map"
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.png",
      "uninstallerIcon": "assets/icon.png",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "BytesProtector"
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "dependencies": {
    "electron-store": "^8.1.0"
  }
}